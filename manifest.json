{
    "manifest_version": 3,
    "name": "Bili2Gemini 视频提炼助手",
    "version": "1.0.0",
    "description": "一键将 Bilibili/YouTube 视频的字幕与评论区精华提取，并无缝直通 Gemini 进行 AI 总结提炼。",
    "short_name": "Bili2Gemini",
    "permissions": [
        "activeTab",
        "storage",
        "clipboardRead"
    ],
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/watch*",
                "https://www.bilibili.com/video/*",
                "https://bilibili.com/video/*",
                "https://gemini.google.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "style.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "bili-q-tldr-pro@zuoyi.custom",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}